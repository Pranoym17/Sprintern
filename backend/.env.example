RESEND_FROM_EMAIL=Sprintern Alerts <alerts@example.com>
RESEND_WEBHOOK_SECRET=whsec_replace_with-resend-webhook-secret
UNSUBSCRIBE_SIGNING_SECRET=replace-with-at-least-32-random-characters
SUPPORT_EMAIL=support@example.com
INTERNAL_API_KEY=replace-with-at-least-32-random-characters

NOTIFICATION_MAX_ATTEMPTS=5
NOTIFICATION_LEASE_SECONDS=300
SCHEDULER_SOURCE_CONFIG=config/sources.toml
SCHEDULER_NOTIFICATION_INTERVAL_SECONDS=30
SCHEDULER_HEARTBEAT_INTERVAL_SECONDS=30
SCHEDULER_TIMEZONE=UTC
SCHEDULER_MISFIRE_GRACE_SECONDS=60
SCHEDULER_SHUTDOWN_TIMEOUT_SECONDS=30
WORKER_POLL_INTERVAL_SECONDS=1
WORKER_LEASE_SECONDS=300
SCHEDULER_SOURCE_SYNC_SECONDS=60
SOURCE_STALE_AFTER_HOURS=24

RATE_LIMIT_ENABLED=true
RATE_LIMIT_BACKEND=memory
RATE_LIMIT_REDIS_URL=
