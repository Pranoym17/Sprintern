FROM python:3.12-slim AS runtime

ENV PYTHONDONTWRITEBYTECODE=1 \
    PYTHONUNBUFFERED=1 \
    PIP_NO_CACHE_DIR=1

WORKDIR /app

RUN addgroup --system sprintern && adduser --system --ingroup sprintern sprintern

COPY pyproject.toml alembic.ini ./
COPY api ./api
COPY migrations ./migrations
COPY config ./config
RUN python -m pip install .

USER sprintern
EXPOSE 8010

CMD ["python", "-m", "uvicorn", "api.main:app", "--host", "0.0.0.0", "--port", "8010", "--workers", "1", "--no-proxy-headers"]
