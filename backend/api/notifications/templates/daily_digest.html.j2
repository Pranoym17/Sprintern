{% extends "base_email.html.j2" %}
{% block content %}
<tr>
  <td style="padding:16px 28px 12px;">
    <h1 class="heading" style="margin:0 0 10px;font-family:Arial,Helvetica,sans-serif;font-size:28px;line-height:1.2;letter-spacing:-0.7px;color:#171512;">Today’s strongest matches</h1>
    <p class="body" style="margin:0;font-family:Arial,Helvetica,sans-serif;font-size:15px;line-height:1.6;color:#69645c;">We ranked today’s new internships by match strength and freshness. Here are your top {{ jobs|length }}.</p>
  </td>
</tr>
{% for job in jobs %}
<tr>
  <td style="padding:12px 28px;">
    <table class="job-card" role="presentation" width="100%" cellspacing="0" cellpadding="0" border="0" style="width:100%;background:#ffffff;border:1px solid #d8d0c3;border-radius:12px;">
      <tr>
        <td style="padding:20px;">
          <p class="job-meta" style="margin:0 0 6px;font-family:Arial,Helvetica,sans-serif;font-size:12px;font-weight:700;letter-spacing:0.7px;text-transform:uppercase;color:#69645c;">{{ job.company }}</p>
          <h2 class="job-title" style="margin:0 0 10px;font-family:Arial,Helvetica,sans-serif;font-size:20px;line-height:1.3;color:#171512;">{{ job.title }}</h2>
          <p class="job-meta" style="margin:0 0 18px;font-family:Arial,Helvetica,sans-serif;font-size:14px;line-height:1.5;color:#69645c;">{{ job.location }}{% if job.term %} &middot; {{ job.term }}{% endif %}</p>
          <table role="presentation" cellspacing="0" cellpadding="0" border="0">
            <tr>
              <td style="border-radius:8px;background:#ef4f32;">
                <a href="{{ job.application_url }}" style="display:inline-block;padding:11px 17px;font-family:Arial,Helvetica,sans-serif;font-size:14px;font-weight:700;color:#ffffff;text-decoration:none;">Apply now</a>
              </td>
            </tr>
          </table>
        </td>
      </tr>
    </table>
  </td>
</tr>
{% endfor %}
<tr><td style="height:8px;font-size:0;line-height:0;">&nbsp;</td></tr>
{% endblock %}
