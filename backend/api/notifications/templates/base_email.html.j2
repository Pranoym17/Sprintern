<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <meta name="color-scheme" content="light dark">
    <meta name="supported-color-schemes" content="light dark">
    <title>{{ subject }}</title>
    <style>
      :root { color-scheme: light dark; supported-color-schemes: light dark; }
      @media (prefers-color-scheme: dark) {
        .page { background: #171512 !important; }
        .panel, .job-card { background: #23201c !important; border-color: #4a443c !important; }
        .heading, .job-title { color: #fffdf8 !important; }
        .body, .job-meta, .footer { color: #c8c0b5 !important; }
        .footer-link { color: #ff8a74 !important; }
      }
    </style>
  </head>
  <body class="page" style="margin:0;padding:0;background:#f5f1e8;color:#171512;">
    <table role="presentation" width="100%" cellspacing="0" cellpadding="0" border="0" style="width:100%;background:#f5f1e8;">
      <tr>
        <td align="center" style="padding:32px 12px;">
          <table class="panel" role="presentation" width="100%" cellspacing="0" cellpadding="0" border="0" style="width:100%;max-width:620px;background:#fffdf8;border:1px solid #d8d0c3;border-radius:16px;">
            <tr>
              <td style="padding:28px 28px 8px;">
                <div style="font-family:Arial,Helvetica,sans-serif;font-size:18px;font-weight:800;letter-spacing:-0.3px;color:#171512;">SPRINTERN<span style="color:#ef4f32;">.</span></div>
              </td>
            </tr>
            {% block content %}{% endblock %}
            <tr>
              <td style="padding:8px 28px 28px;">
                <table role="presentation" width="100%" cellspacing="0" cellpadding="0" border="0" style="border-top:1px solid #d8d0c3;">
                  <tr>
                    <td class="footer" style="padding-top:20px;font-family:Arial,Helvetica,sans-serif;font-size:12px;line-height:1.7;color:#69645c;">
                      <a class="footer-link" href="{{ filters_url }}" style="color:#c93620;text-decoration:underline;">Manage your filters</a>
                      &nbsp;&middot;&nbsp;
                      <a class="footer-link" href="{{ settings_url }}" style="color:#c93620;text-decoration:underline;">Notification settings</a>
                      &nbsp;&middot;&nbsp;
                      <a class="footer-link" href="{{ unsubscribe_url }}" style="color:#c93620;text-decoration:underline;">Unsubscribe</a>
                      <br>
                      Need help? <a class="footer-link" href="mailto:{{ support_email }}" style="color:#c93620;text-decoration:underline;">{{ support_email }}</a>
                    </td>
                  </tr>
                </table>
              </td>
            </tr>
          </table>
        </td>
      </tr>
    </table>
  </body>
</html>
