{
  "name": "sprintern",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "dev:api": ".venv\\Scripts\\python -m uvicorn api.main:app --reload --port 8010",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "set PLAYWRIGHT_BROWSERS_PATH=0&& playwright test",
    "lint:api": ".venv\\Scripts\\python -m ruff check api tests migrations",
    "format:api": ".venv\\Scripts\\python -m ruff format api tests migrations",
    "test:api": ".venv\\Scripts\\python -m pytest",
    "typecheck:api": ".venv\\Scripts\\python -m mypy api"
  },
  "dependencies": {
    "@supabase/ssr": "^0.12.3",
    "@supabase/supabase-js": "^2.110.7",
    "lucide-react": "^1.24.0",
    "next": "16.2.10",
    "react": "19.2.4",
    "react-dom": "19.2.4"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@tailwindcss/postcss": "^4",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.10",
    "jsdom": "^29.1.1",
    "tailwindcss": "^4",
    "typescript": "^7",
    "vitest": "^4.1.10"
  }
}
